{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": { "@core/*": ["core/*"], "@/*": ["src/*"] }
  },
  "include": ["electron", "core", "src", "tests"]
}
